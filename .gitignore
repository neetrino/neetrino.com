r2-upload-config.local.json
scripts/assets/r2-upload-config.local.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma generated client
/lib/generated/prisma/

# reference clone (neetrino/-Rules-Template)
/rules-template/
