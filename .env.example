# Copy to `.env.local` and fill in values:
#   cp .env.example .env.local
#
# Local dev: set origin with port — `pnpm dev` reads the port from here.
# Example (if :3000 is taken by another app): http://localhost:3001
APP_URL=http://localhost:3030

# PostgreSQL (Neon)
DATABASE_URL=
DIRECT_URL=

# Admin panel
ADMIN_EMAIL=
ADMIN_PASSWORD=
AUTH_SECRET=

# Cloudflare R2
CF_ACCOUNT_ID=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ArCa / IDBank payments
ARCA_TEST_MODE=true
ARCA_BANK=idbank
ARCA_USERNAME=
ARCA_PASSWORD=
ARCA_LIVE_USERNAME=
ARCA_LIVE_PASSWORD=
PAYMENT_RECONCILE_SECRET=

# Optional — LAN / alternate dev hostnames for Next.js `allowedDevOrigins` (comma-separated, no protocol).
# Example when your machine IP changes: DEV_ALLOWED_ORIGINS=192.168.15.50,192.168.1.100
DEV_ALLOWED_ORIGINS=

# Optional
ADMIN_SESSION_COOKIE_NAME=
ADMIN_SESSION_TTL_SECONDS=
ADMIN_SESSION_COOKIE_DOMAIN=
ADMIN_SERVER_ACTION_ALLOWED_ORIGINS=
ADMIN_AUTH_DEBUG=false
NEXT_PUBLIC_ADMIN_AUTH_DEBUG=false
BLOG_IMAGE_REMOTE_HOSTNAMES=
ANALYZE=false
