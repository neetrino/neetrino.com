{
  "name": "neetrino",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint -c config/eslint.config.mjs .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-portfolio": "tsx prisma/seed-portfolio-static.ts",
    "portfolio:migrate-upload-prefix": "tsx scripts/portfolio/migrate-current-portfolio-cards-to-r2-upload.ts",
    "portfolio:keep-only-slot": "tsx scripts/portfolio/keep-only-portfolio-slot.ts",
    "db:studio": "prisma studio",
    "format": "prettier --write . --config config/prettier.config.cjs",
    "format:check": "prettier --check . --config config/prettier.config.cjs",
    "test": "vitest run --config config/vitest.config.ts",
    "test:watch": "vitest --config config/vitest.config.ts",
    "postinstall": "prisma generate",
    "prepare": "husky",
    "assets:localize-figma": "node scripts/assets/localize-figma-assets.mjs",
    "assets:about-us-webp": "node scripts/assets/localize-about-us-mcp-assets.mjs",
    "assets:optimize-large-webp": "node scripts/assets/optimize-large-public-images.mjs",
    "assets:optimize-local": "node scripts/assets/optimize-local-assets.mjs",
    "assets:convert-png-webp": "node scripts/convert-images.mjs",
    "assets:r2-upload": "node scripts/assets/r2-upload-assets.mjs"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css}": [
      "prettier --write --config config/prettier.config.cjs"
    ],
    "*.{ts,tsx,js,jsx}": [
      "eslint -c config/eslint.config.mjs"
    ]
  },
  "pnpm": {
    "overrides": {
      "vite": ">=7.3.2",
      "fast-uri": ">=3.1.2",
      "fast-xml-builder": ">=1.1.7"
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "iconoir-react": "^7.11.0",
    "jose": "^6.2.3",
    "liquid-glass-react": "^1.1.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.6",
    "next-intl": "^4.9.1",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "three": "^0.167.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "husky": "^9.1.7",
    "jsdom": "^27.0.0",
    "lint-staged": "^16.0.0",
    "prettier": "^3.5.0",
    "prisma": "^7.8.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3.0.0"
  }
}
